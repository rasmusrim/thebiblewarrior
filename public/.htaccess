# SPA fallback — route all unknown paths to index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule . /index.html [L]
</IfModule>

# Force HTTPS (but let ACME HTTP-01 challenges through)
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} !=on
  RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Correct MIME type for the PWA manifest
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# Long-cache hashed build assets, never cache HTML/manifest
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|mp3|ogg|m4a)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|webmanifest|json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
